{
  "extends": ["@commitlint/config-conventional"],
  "rules": {
    "type-enum": [2, "always", [
      "feat", "fix", "docs", "style",
      "refactor", "perf", "build", "ci", "chore", "revert"
    ]],
    "scope-enum": [1, "always", [
      "auth", "user", "role", "article",
      "category", "upload", "ui", "web",
      "admin", "api", "db", "docker", "ci"
    ]],
    "subject-max-length": [2, "always", 100]
  }
}
